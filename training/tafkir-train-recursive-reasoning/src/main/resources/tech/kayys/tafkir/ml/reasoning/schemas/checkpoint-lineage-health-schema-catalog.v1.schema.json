{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aljabr.ai/schemas/training/checkpoint-lineage-health-schema-catalog.v1.schema.json",
  "title": "Aljabr checkpoint lineage health schema catalog",
  "description": "Stable schema catalog for recursive-reasoning checkpoint lineage health payload contracts.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "kind",
    "schemaVersion",
    "catalogSchemaId",
    "catalogSchemaResource",
    "catalogSchemaSha256",
    "catalogSchemaByteCount",
    "schemaSetSha256",
    "schemaSetByteCount",
    "schemaCount",
    "contracts",
    "summary"
  ],
  "properties": {
    "kind": {
      "const": "checkpoint-lineage-health-schema-catalog"
    },
    "schemaVersion": {
      "const": "aljabr.checkpoint-lineage-health-schema-catalog.v1"
    },
    "catalogSchemaId": {
      "const": "https://aljabr.ai/schemas/training/checkpoint-lineage-health-schema-catalog.v1.schema.json"
    },
    "catalogSchemaResource": {
      "const": "tech/kayys/aljabr/ml/reasoning/schemas/checkpoint-lineage-health-schema-catalog.v1.schema.json"
    },
    "catalogSchemaSha256": {
      "$ref": "#/$defs/sha256"
    },
    "catalogSchemaByteCount": {
      "$ref": "#/$defs/positiveInteger"
    },
    "schemaSetSha256": {
      "$ref": "#/$defs/sha256"
    },
    "schemaSetByteCount": {
      "$ref": "#/$defs/positiveInteger"
    },
    "schemaCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "contracts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contract"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "label",
        "payloadKind",
        "payloadSchemaVersion",
        "jsonSchemaId",
        "jsonSchemaResource",
        "jsonSchemaSha256",
        "jsonSchemaByteCount",
        "jsonSchemaDraft",
        "title",
        "description",
        "inspectorSections"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "payloadKind": {
          "type": "string",
          "minLength": 1
        },
        "payloadSchemaVersion": {
          "type": "string",
          "minLength": 1
        },
        "jsonSchemaId": {
          "type": "string",
          "minLength": 1
        },
        "jsonSchemaResource": {
          "type": "string",
          "minLength": 1
        },
        "jsonSchemaSha256": {
          "$ref": "#/$defs/sha256"
        },
        "jsonSchemaByteCount": {
          "$ref": "#/$defs/positiveInteger"
        },
        "jsonSchemaDraft": {
          "const": "https://json-schema.org/draft/2020-12/schema"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "inspectorSections": {
          "$ref": "#/$defs/stringArray"
        },
        "schema": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
