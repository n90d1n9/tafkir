{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aljabr.ai/schemas/training/checkpoint-lineage-health-schema-lock-validation.v1.schema.json",
  "title": "Aljabr checkpoint lineage health schema lock validation report",
  "description": "Stable valid/invalid report emitted when a recursive-reasoning checkpoint lineage health schema lock is compared with the current schema set.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "kind",
    "schemaVersion",
    "validationSchemaId",
    "validationSchemaResource",
    "status",
    "valid",
    "code",
    "message",
    "expectedSchemaSetSha256",
    "actualSchemaSetSha256",
    "schemaSetMatch",
    "expectedSchemaCount",
    "actualSchemaCount",
    "expectedLockSchemaId",
    "actualLockSchemaId",
    "mismatchCount",
    "mismatches",
    "summary"
  ],
  "properties": {
    "kind": {
      "const": "checkpoint-lineage-health-schema-lock-validation"
    },
    "schemaVersion": {
      "const": "aljabr.checkpoint-lineage-health-schema-lock-validation.v1"
    },
    "validationSchemaId": {
      "const": "https://aljabr.ai/schemas/training/checkpoint-lineage-health-schema-lock-validation.v1.schema.json"
    },
    "validationSchemaResource": {
      "const": "tech/kayys/aljabr/ml/reasoning/schemas/checkpoint-lineage-health-schema-lock-validation.v1.schema.json"
    },
    "status": {
      "enum": [
        "valid",
        "invalid"
      ]
    },
    "valid": {
      "type": "boolean"
    },
    "code": {
      "enum": [
        "ALJABR_LINEAGE_HEALTH_SCHEMA_LOCK_VALID",
        "ALJABR_LINEAGE_HEALTH_SCHEMA_LOCK_MISMATCH"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "expectedSchemaSetSha256": {
      "$ref": "#/$defs/sha256"
    },
    "actualSchemaSetSha256": {
      "$ref": "#/$defs/sha256"
    },
    "schemaSetMatch": {
      "type": "boolean"
    },
    "expectedSchemaCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "actualSchemaCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "expectedLockSchemaId": {
      "type": "string",
      "minLength": 1
    },
    "actualLockSchemaId": {
      "const": "https://aljabr.ai/schemas/training/checkpoint-lineage-health-schema-lock.v1.schema.json"
    },
    "mismatchCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "mismatches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mismatch"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "valid": {
            "const": true
          }
        },
        "required": [
          "valid"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "valid"
          },
          "code": {
            "const": "ALJABR_LINEAGE_HEALTH_SCHEMA_LOCK_VALID"
          },
          "schemaSetMatch": {
            "const": true
          },
          "mismatchCount": {
            "const": 0
          },
          "mismatches": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "valid": {
            "const": false
          }
        },
        "required": [
          "valid"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "invalid"
          },
          "code": {
            "const": "ALJABR_LINEAGE_HEALTH_SCHEMA_LOCK_MISMATCH"
          },
          "mismatchCount": {
            "minimum": 1
          },
          "mismatches": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "mismatch": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "path",
        "expected",
        "actual"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "expected": true,
        "actual": true
      }
    }
  }
}
