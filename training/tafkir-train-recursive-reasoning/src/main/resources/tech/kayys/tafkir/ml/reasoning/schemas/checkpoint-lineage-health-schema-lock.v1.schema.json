{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aljabr.ai/schemas/training/checkpoint-lineage-health-schema-lock.v1.schema.json",
  "title": "Aljabr checkpoint lineage health schema lock",
  "description": "Stable lock payload for pinning the recursive-reasoning checkpoint lineage health schema set.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "kind",
    "schemaVersion",
    "schemaSetSha256",
    "schemaSetByteCount",
    "schemaCount",
    "catalogSchemaId",
    "catalogSchemaSha256",
    "lockSchemaId",
    "contracts",
    "summary"
  ],
  "properties": {
    "kind": {
      "const": "checkpoint-lineage-health-schema-lock"
    },
    "schemaVersion": {
      "const": "aljabr.checkpoint-lineage-health-schema-lock.v1"
    },
    "schemaSetSha256": {
      "$ref": "#/$defs/sha256"
    },
    "schemaSetByteCount": {
      "$ref": "#/$defs/positiveInteger"
    },
    "schemaCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "catalogSchemaId": {
      "const": "https://aljabr.ai/schemas/training/checkpoint-lineage-health-schema-catalog.v1.schema.json"
    },
    "catalogSchemaSha256": {
      "$ref": "#/$defs/sha256"
    },
    "lockSchemaId": {
      "const": "https://aljabr.ai/schemas/training/checkpoint-lineage-health-schema-lock.v1.schema.json"
    },
    "contracts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contract"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "payloadKind",
        "payloadSchemaVersion",
        "jsonSchemaId",
        "jsonSchemaSha256",
        "jsonSchemaByteCount"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "payloadKind": {
          "type": "string",
          "minLength": 1
        },
        "payloadSchemaVersion": {
          "type": "string",
          "minLength": 1
        },
        "jsonSchemaId": {
          "type": "string",
          "minLength": 1
        },
        "jsonSchemaSha256": {
          "$ref": "#/$defs/sha256"
        },
        "jsonSchemaByteCount": {
          "$ref": "#/$defs/positiveInteger"
        }
      }
    }
  }
}
